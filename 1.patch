+local o = vim.o
 -- o.cursorlineopt ='both' -- to enable cursorline!
+
+o.relativenumber = true
+
+vim.api.nvim_create_autocmd({'bufEnter', 'BufWinEnter'}, {
+  pattern = {'*.c', '*.h'},
+  callback = function ()
+    o.tabstop = 4
+    o.shiftwidth = 4
+    o.expandtab = true
+    o.cindent = true
+  end
+})
